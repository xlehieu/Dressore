<div class="mt-4">
    <div class="row">
        {{#each products}}
        <div class="col-sm-6 col-lg-4">
            <div class="card" style="width: 18rem;">         
            <a href="/courses/{{this.slug}}">
            <img class="card-img-top" src={{this.thumb}} alt={{this.name}} />
          </a>
            <div class="card-body">
                <a href="{{this.slug}}">
                    <h5 class="card-title">{{this.name}}</h5>
                </a>
                <p class="card-text">{{this.price}}</p>
                <p class="card-text">{{this.category}}</p>
                
            </div>
            </div>
        </div>
        {{/each}}

    </div>
</div>